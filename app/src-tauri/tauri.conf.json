{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Aeterna",
  "version": "1.0.0",
  "identifier": "com.aeterna.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Aeterna",
        "width": 1440,
        "height": 960,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "../../ml/models/latency_model.metadata.json",
      "../../ml/shap/latest.json"
    ],
    "externalBin": [
      "binaries/aeterna-core",
      "binaries/aeterna-sidecar"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "installerHooks": "./windows/hooks.nsh"
      }
    },
    "icon": [
      "icons/icon.ico"
    ]
  }
}
